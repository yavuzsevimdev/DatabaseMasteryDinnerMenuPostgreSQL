<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    /* ── Canlı Tarih ── */
    (function(){
    const tr = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
    const mo = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
    const d = new Date();
    document.getElementById('liveDate').textContent =
    tr[d.getDay()] + ', ' + d.getDate() + ' ' + mo[d.getMonth()] + ' ' + d.getFullYear();
    })();

    /* ── Ortak Chart Defaults ── */
    Chart.defaults.font.family = "'DM Sans', sans-serif";
    Chart.defaults.font.size   = 12;
    Chart.defaults.color       = '#9a9590';

    /* ── 1. ── */

    new Chart(document.getElementById('lineChart'), {
    type: 'line',
    data: {
    labels: window.lineChartLabels,
    datasets: [{
    label: 'Rezervasyon',
    data: window.lineChartData,
    borderColor: '#e6a03c',
    backgroundColor: 'rgba(230,160,60,0.08)',
    borderWidth: 2.5,
    pointBackgroundColor: '#e6a03c',
    pointBorderColor: '#fff',
    pointBorderWidth: 2,
    pointRadius: 5,
    tension: 0.4,
    fill: true,
    }]
    },
    options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
    x: { grid: { color: '#f5f2ee' }, border: { display: false } },
    y: { grid: { color: '#f5f2ee' }, border: { display: false }, ticks: { stepSize: 1 }, beginAtZero: true }
    }
    }
    });

    /* ── 2. Bar Grafik (Kategori Sipariş) ── */
    /* ── 2. Bar Grafik (Kategoriye Göre Ürün Sayısı) ── */
    new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
    labels: window.barChartLabels,
    datasets: [{
    label: 'Ürün Sayısı',
    data: window.barChartData,
    backgroundColor: [
    'rgba(139,92,246,0.7)',
    'rgba(230,160,60,0.8)',
    'rgba(34,197,94,0.7)',
    'rgba(59,130,246,0.7)',
    'rgba(20,184,166,0.7)',
    'rgba(239,68,68,0.7)',
    'rgba(245,158,11,0.7)',
    ],
    borderRadius: 7,
    borderSkipped: false,
    }]
    },
    options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
    x: { grid: { display: false }, border: { display: false } },
    y: { grid: { color: '#f5f2ee' }, border: { display: false }, beginAtZero: true, ticks: { stepSize: 1 } }
    }
    }
    });

    /* ── 3. Pasta Grafik (Kategori Ortalama Fiyat) ── */
    new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: {
    labels: window.pieChartLabels,
    datasets: [{
    data: window.pieChartData,
    backgroundColor: ['#e6a03c','#3b82f6','#22c55e','#8b5cf6','#14b8a6','#ef4444','#f59e0b'],
    borderWidth: 0,
    hoverOffset: 6,
    }]
    },
    options: {
    responsive: true, maintainAspectRatio: false,
    cutout: '68%',
    plugins: {
    legend: { display: false },
    tooltip: {
    callbacks: {
    label: ctx => ' ₺' + parseFloat(ctx.parsed).toFixed(2)
    }
    }
    }
    }
    });
</script>