                </div>

                <div class="summary-row">
                    <div class="sr-icon"><i class="bi bi-clock-fill"></i></div>
                    <div>
                        <div class="sr-lbl">Saat</div>
                        <div class="sr-val" id="sumTime">—</div>
                    </div>
                </div>

                <div class="summary-row">
                    <div class="sr-icon"><i class="bi bi-people-fill"></i></div>
                    <div>
                        <div class="sr-lbl">Kişi Sayısı</div>
                        <div class="sr-val" id="sumGuest">2 kişi</div>
                    </div>
                </div>

                <hr class="summary-divider" />

                <div class="summary-row">
                    <div class="sr-icon"><i class="bi bi-circle-fill"></i></div>
