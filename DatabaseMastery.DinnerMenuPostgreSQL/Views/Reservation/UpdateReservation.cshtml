                </div>
            </div>

        </div>

    </div>
</form>

@section Scripts {
    <script>
        /* ── GUEST STEPPER ── */
        function changeGuest(delta) {
            var inp = document.getElementById('inpGuest');
            var val = parseInt(inp.value) || 2;
            val = Math.min(50, Math.max(1, val + delta));
            inp.value = val;
            updateSummary();
        }

        /* ── STATUS SELECTOR ── */
        var statusMap = {
            'Beklemede':    'opt-beklemede',
            'Onaylandı':    'opt-onaylandi',
            'İptal Edildi': 'opt-iptal'
        };
        var statusClassMap = {
            'Beklemede':    'selected-beklemede',
            'Onaylandı':    'selected-onaylandi',
            'İptal Edildi': 'selected-iptal'
        };

        function selectStatus(val) {
            document.getElementById('hiddenStatus').value = val;

            // Reset all
            Object.keys(statusMap).forEach(function(k) {
                var el = document.getElementById(statusMap[k]);
                el.className = 'status-option';
            });

            // Activate selected
            var target = document.getElementById(statusMap[val]);
            if (target) target.classList.add(statusClassMap[val]);

            updateSummary();
        }

        /* ── LIVE SUMMARY ── */
        var TR_DAYS   = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
        var TR_MONTHS = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];

        function updateSummary() {
            /* Name */
            var name = (document.getElementById('inpName').value || '').trim();
            document.getElementById('sumName').textContent = name || '—';

            /* Phone */
            var phone = (document.getElementById('inpPhone').value || '').trim();
            document.getElementById('sumPhone').textContent = phone || '—';

            /* Date */
            var dateVal = document.getElementById('inpDate').value;
            if (dateVal) {
                var d = new Date(dateVal + 'T00:00:00');
                var formatted = TR_DAYS[d.getDay()] + ', ' + d.getDate() + ' ' + TR_MONTHS[d.getMonth()] + ' ' + d.getFullYear();
                document.getElementById('sumDate').textContent = formatted;
            } else {
                document.getElementById('sumDate').textContent = '—';
            }

            /* Time */
            var timeVal = document.getElementById('inpTime').value;
            document.getElementById('sumTime').textContent = timeVal || '—';

            /* Guest */
            var guest = parseInt(document.getElementById('inpGuest').value) || 2;
            document.getElementById('sumGuest').textContent = guest + ' kişi';

            /* Status */
            document.getElementById('sumStatus').textContent = document.getElementById('hiddenStatus').value;
        }

        /* ── SET MIN DATE (today) ── */
        document.addEventListener('DOMContentLoaded', function () {
            var today = new Date().toISOString().split('T')[0];
            document.getElementById('inpDate').setAttribute('min', today);
            updateSummary();
        });
    </script>
}
